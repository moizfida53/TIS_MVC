    if (selTabIndex > 0) {
        window.sessionStorage['SelectedTabIndex'] = 1;
        displayTabDetails(selTabIndex);
    }
    else {
        if ($('#selectedTabId').val() > 0) {
            displayTabDetails($('#selectedTabId').val());
            SelectedtbIndex = $('#selectedTabId').val();
        }
        else {
            SelectedtbIndex = 1;
        }
