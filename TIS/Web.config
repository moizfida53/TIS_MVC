	<connectionStrings>
		<add name="SqlServerConnection" connectionString="Server=.\SQLEXPRESS;Database=TIS_KDD; uid=sa;password=sa#1234" providerName="System.Data.SqlClient" />
	</connectionStrings>
	<appSettings>
		<add key="webpages:Version" value="2.0.0.0" />
		<add key="webpages:Enabled" value="false" />
		<add key="PreserveLoginUrl" value="true" />
		<add key="ClientValidationEnabled" value="true" />
		<add key="UnobtrusiveJavaScriptEnabled" value="true" />
		<add key="autoFormsAuthentication" value="false" />
		<add key="enableSimpleMembership" value="false" />
		<add key="LoginName" value="FAjin" />
		<add key="LDAPPath" value="LDAP://" />
		<add key="AdminID" value="test" />
		<add key="AdminPwd" value="test" />
		<add key="aspnet:MaxJsonDeserializerMembers" value="150000" />
		<add key="SMSSenderUserName" value="" />
		<add key="SMSSenderPassword" value="" />
		<add key="SMSSenderID" value="" />
		<add key="AD.Domain" value="" />
		<add key="AD.LdapPath" value="LDAP://yourdomainName,DC=com,DC=kw" />
		<add key="AD.Attr.DisplayName" value="displayName" />
		<add key="AD.Attr.Email" value="mail" />
		<add key="AD.Attr.Department" value="department" />
		<add key="AD.Attr.EmployeeNumber" value="employeeNumber" />
	</appSettings>
	<system.web>

