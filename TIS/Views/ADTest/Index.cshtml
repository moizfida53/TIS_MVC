@*@model TIS.Models.Users*@
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AD Connection Test</title>

    <style>
        /* ── Reset & base ─────────────────────────────────────────────── */
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #0f1117;
            color: #e2e8f0;
            min-height: 100vh;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding: 48px 16px;
        }

        /* ── Page wrapper ─────────────────────────────────────────────── */
        .page {
            width: 100%;
            max-width: 680px;
        }

        /* ── Header ───────────────────────────────────────────────────── */
        .header {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 36px;
        }

        .header-icon {
            width: 44px;
            height: 44px;
            background: linear-gradient(135deg, #3b82f6, #6366f1);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            flex-shrink: 0;
            box-shadow: 0 4px 20px rgba(99,102,241,.4);
        }

        .header h1 {
            font-size: 1.4rem;
            font-weight: 700;
            letter-spacing: -.3px;
        }

        .header p {
            font-size: .82rem;
            color: #64748b;
            margin-top: 2px;
        }

        /* ── Card ─────────────────────────────────────────────────────── */
        .card {
            background: #1e2330;
            border: 1px solid #2d3548;
            border-radius: 14px;
            padding: 28px 32px;
            margin-bottom: 20px;
        }

        .card-title {
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: #64748b;
            margin-bottom: 20px;
        }

        /* ── Buttons ──────────────────────────────────────────────────── */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 22px;
            border: none;
            border-radius: 8px;
            font-size: .88rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity .15s, transform .1s;
            white-space: nowrap;
        }

            .btn:active {
                transform: scale(.97);
            }

            .btn:disabled {
                opacity: .5;
                cursor: not-allowed;
                transform: none;
            }

        .btn-blue {
            background: #3b82f6;
            color: #fff;
        }

            .btn-blue:hover:not(:disabled) {
                opacity: .88;
            }

        .btn-indigo {
            background: #6366f1;
            color: #fff;
        }

            .btn-indigo:hover:not(:disabled) {
                opacity: .88;
            }

        .btn-green {
            background: #16a34a;
            color: #fff;
            margin-top: 20px;
        }

            .btn-green:hover:not(:disabled) {
                opacity: .88;
            }

        /* ── Connection status badge ──────────────────────────────────── */
        #conn-status {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            border-radius: 8px;
            font-size: .85rem;
            font-weight: 600;
            margin-top: 16px;
            opacity: 0;
            transition: opacity .3s;
        }

            #conn-status.visible {
                opacity: 1;
            }

            #conn-status.success {
                background: #14432a;
                color: #4ade80;
                border: 1px solid #166534;
            }

            #conn-status.fail {
                background: #3b1515;
                color: #f87171;
                border: 1px solid #7f1d1d;
            }

        .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: currentColor;
        }

        /* ── Search row ───────────────────────────────────────────────── */
        .search-row {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .search-input {
            flex: 1;
            padding: 10px 14px;
            background: #0f1117;
            border: 1px solid #2d3548;
            border-radius: 8px;
            color: #e2e8f0;
            font-size: .9rem;
            outline: none;
            transition: border-color .2s;
        }

            .search-input::placeholder {
                color: #475569;
            }

            .search-input:focus {
                border-color: #6366f1;
            }

        /* ── Result table ─────────────────────────────────────────────── */
        #result-box {
            margin-top: 22px;
        }

        .result-table {
            width: 100%;
            border-collapse: collapse;
            font-size: .88rem;
        }

            .result-table tr:not(:last-child) td {
                border-bottom: 1px solid #2d3548;
            }

            .result-table td {
                padding: 11px 0;
                vertical-align: top;
            }

                .result-table td:first-child {
                    width: 40%;
                    color: #64748b;
                    font-size: .78rem;
                    letter-spacing: .5px;
                    text-transform: uppercase;
                    font-weight: 600;
                    padding-right: 12px;
                }

                .result-table td:last-child {
                    color: #e2e8f0;
                    font-weight: 500;
                }

        .no-data {
            color: #64748b;
            font-size: .85rem;
            font-style: italic;
        }

        /* ── Error message ────────────────────────────────────────────── */
        .error-msg {
            background: #3b1515;
            border: 1px solid #7f1d1d;
            color: #f87171;
            border-radius: 8px;
            padding: 12px 16px;
            font-size: .85rem;
            margin-top: 16px;
        }

        /* ── Spinner ──────────────────────────────────────────────────── */
        .spinner {
            width: 16px;
            height: 16px;
            border: 2px solid rgba(255,255,255,.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .6s linear infinite;
            display: none;
        }

            .spinner.active {
                display: block;
            }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* ── Update Mobile — field rows ───────────────────────────────── */
        .field-row {
            display: flex;
            flex-direction: column;
            gap: 6px;
            margin-bottom: 14px;
        }

            .field-row label {
                font-size: .72rem;
                font-weight: 700;
                letter-spacing: 1px;
                text-transform: uppercase;
                color: #64748b;
            }

            .field-row .search-input {
                width: 100%;
            }

        /* ── Mobile status badge (mirrors #conn-status) ───────────────── */
        #mobile-status {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            border-radius: 8px;
            font-size: .85rem;
            font-weight: 600;
            margin-top: 16px;
            opacity: 0;
            transition: opacity .3s;
        }

            #mobile-status.visible {
                opacity: 1;
            }

            #mobile-status.success {
                background: #14432a;
                color: #4ade80;
                border: 1px solid #166534;
            }

            #mobile-status.fail {
                background: #3b1515;
                color: #f87171;
                border: 1px solid #7f1d1d;
            }
    </style>
</head>
<body>
    <div class="page">

        <!-- Header -->
        <div class="header">
            <div class="header-icon">🗂️</div>
            <div>
                <h1>Active Directory Test</h1>
                <p>Test connectivity and search for users in your AD environment</p>
            </div>
        </div>

        <!-- Card 1 — Connection Test -->
        <div class="card">
            <div class="card-title">Connection Test</div>

            <button class="btn btn-blue" id="btn-test"
                    data-url="@Url.Action("TestConnection", "ADTest" )">
                <span id="conn-spinner" class="spinner"></span>
                🔌 Test AD Connection
            </button>

            <div id="conn-status">
                <span class="dot"></span>
                <span id="conn-msg"></span>
            </div>
        </div>

        <!-- Card 2 — User Search -->
        <div class="card">
            <div class="card-title">Search User</div>

            <div class="search-row">
                <input class="search-input"
                       type="text"
                       id="username-input"
                       placeholder="Enter sAMAccountName (e.g. jsmith)" />

                <button class="btn btn-indigo" id="btn-search"
                        data-url="@Url.Action("SearchUser", "ADTest" )">
                    <span id="search-spinner" class="spinner"></span>
                    🔍 Search AD
                </button>
            </div>

            <div id="result-box"></div>
        </div>

        <!-- Card 3 — Update Mobile Number -->
        <div class="card">
            <div class="card-title">Update Mobile Number</div>

            <div class="field-row">
                <label for="mobile-username-input">Username (sAMAccountName)</label>
                <input class="search-input"
                       type="text"
                       id="mobile-username-input"
                       placeholder="e.g. john.doe"
                       autocomplete="off" />
            </div>

            <div class="field-row">
                <label for="mobile-number-input">Mobile Number</label>
                <input class="search-input"
                       type="text"
                       id="mobile-number-input"
                       placeholder="e.g. +96599123456"
                       autocomplete="off" />
            </div>

            <button class="btn btn-green" id="btn-update-mobile"
                    data-url="@Url.Action("UpdateMobile", "ADTest")">
                <span id="update-spinner" class="spinner"></span>
                📱 Update Mobile
            </button>

            <div id="mobile-status">
                <span class="dot"></span>
                <span id="mobile-msg"></span>
            </div>
        </div>

    </div>

    <script src="~/Scripts/adtest.js"></script>
</body>
</html>
