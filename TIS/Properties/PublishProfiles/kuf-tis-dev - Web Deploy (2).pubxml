<?xml version="1.0" encoding="utf-8"?>
<!--
This file is used by the publish/package process of your Web project. You can customize the behavior of this process
by editing this MSBuild file. In order to learn more about this please visit http://go.microsoft.com/fwlink/?LinkID=208121. 
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <WebPublishMethod>MSDeploy</WebPublishMethod>
    <ADUsesOwinOrOpenIdConnect>False</ADUsesOwinOrOpenIdConnect>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish>http://kuf-tis-dev.azurewebsites.net</SiteUrlToLaunchAfterPublish>
    <LaunchSiteAfterPublish>True</LaunchSiteAfterPublish>
    <ExcludeApp_Data>False</ExcludeApp_Data>
    <MSDeployServiceURL>kuf-tis-dev.scm.azurewebsites.net:443</MSDeployServiceURL>
    <DeployIisAppPath>kuf-tis-dev</DeployIisAppPath>
    <RemoteSitePhysicalPath />
    <SkipExtraFilesOnServer>True</SkipExtraFilesOnServer>
    <MSDeployPublishMethod>WMSVC</MSDeployPublishMethod>
    <EnableMSDeployBackup>True</EnableMSDeployBackup>
    <UserName>$kuf-tis-dev</UserName>
    <_SavePWD>True</_SavePWD>
    <PublishDatabaseSettings>
      <Objects xmlns="">
        <ObjectGroup Name="SqlServerConnectionString" Order="1" Enabled="False">
          <Destination Path="" />
          <Object Type="DbDacFx">
            <PreSource Path="Provider=sqloledb;Data Source=kuf-sql-dev;Initial Catalog=TIS_2018;Persist Security Info=True;User ID=tismvc;Password=test;" includeData="False" />
            <Source Path="$(IntermediateOutputPath)AutoScripts\SqlServerConnectionString_IncrementalSchemaOnly.dacpac" dacpacAction="Deploy" />
          </Object>
          <UpdateFrom Type="Web.Config">
            <Source MatchValue="Provider=sqloledb;Data Source=kuf-sql-dev;Initial Catalog=TIS_2018;Persist Security Info=True;User ID=tismvc;Password=test;" MatchAttributes="$(UpdateFromConnectionStringAttributes)" />
          </UpdateFrom>
        </ObjectGroup>
        <ObjectGroup Name="ConnStr1" Order="4" Enabled="False">
          <Destination Path="" />
          <Object Type="DbDacFx">
            <PreSource Path="Data Source=kuf-sql-dev;Initial Catalog=kuf-sql-dev;User ID=tismvc;Password=TIS_2018;Pooling=false" includeData="False" />
            <Source Path="$(IntermediateOutputPath)AutoScripts\ConnStr1_IncrementalSchemaOnly.dacpac" dacpacAction="Deploy" />
          </Object>
          <UpdateFrom Type="Web.Config">
            <Source MatchValue="Data Source=kuf-sql-dev;Initial Catalog=kuf-sql-dev;User ID=tismvc;Password=TIS_2018;Pooling=false" MatchAttributes="$(UpdateFromConnectionStringAttributes)" />
          </UpdateFrom>
        </ObjectGroup>
        <ObjectGroup Name="ConnStr" Order="5" Enabled="False">
          <Destination Path="" />
          <Object Type="DbDacFx">
            <PreSource Path="Data Source=kuf-sql-dev;Initial Catalog=kuf-sql-dev;User ID=tismvc;Password=TIS_2018;Pooling=false" includeData="False" />
            <Source Path="$(IntermediateOutputPath)AutoScripts\ConnStr_IncrementalSchemaOnly.dacpac" dacpacAction="Deploy" />
          </Object>
          <UpdateFrom Type="Web.Config">
            <Source MatchValue="Data Source=kuf-sql-dev;Initial Catalog=kuf-sql-dev;User ID=tismvc;Password=TIS_2018;Pooling=false" MatchAttributes="$(UpdateFromConnectionStringAttributes)" />
          </UpdateFrom>
        </ObjectGroup>
        <ObjectGroup Name="TISMVCEntities" Order="6" Enabled="False">
          <Destination Path="Data Source=EQSHEPP1;User ID=tismvc;Application Name=EntityFramework" Name="Data Source=EQSHEPP1;User ID=tismvc;MultipleActiveResultSets=True;Application Name=EntityFramework" />
          <Object Type="DbDacFx">
            <PreSource Path="Data Source=EQSHEPP1;User ID=tismvc;Application Name=EntityFramework" includeData="False" />
            <Source Path="$(IntermediateOutputPath)AutoScripts\TISMVCEntities_IncrementalSchemaOnly.dacpac" dacpacAction="Deploy" />
          </Object>
          <UpdateFrom Type="Web.Config">
            <Source MatchValue="metadata=res://*/Models.PivotTable.csdl|res://*/Models.PivotTable.ssdl|res://*/Models.PivotTable.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=EQSHEPP1;user id=tismvc;MultipleActiveResultSets=True;App=EntityFramework&quot;" MatchAttributes="$(UpdateFromConnectionStringAttributes)" />
          </UpdateFrom>
        </ObjectGroup>
      </Objects>
    </PublishDatabaseSettings>
    <_DestinationType>AzureWebSite</_DestinationType>
    <PrecompileBeforePublish>True</PrecompileBeforePublish>
    <EnableUpdateable>True</EnableUpdateable>
    <DebugSymbols>False</DebugSymbols>
    <WDPMergeOption>DonotMerge</WDPMergeOption>
  </PropertyGroup>
  <ItemGroup>
    <MSDeployParameterValue Include="$(DeployParameterPrefix)ConnStr-Web.config Connection String" />
    <MSDeployParameterValue Include="$(DeployParameterPrefix)ConnStr1-Web.config Connection String" />
    <MSDeployParameterValue Include="$(DeployParameterPrefix)SqlServerConnectionString-Web.config Connection String" />
    <MSDeployParameterValue Include="$(DeployParameterPrefix)TISMVCEntities-Web.config Connection String">
      <ParameterValue>metadata=res://*/Models.PivotTable.csdl|res://*/Models.PivotTable.ssdl|res://*/Models.PivotTable.msl;provider=System.Data.SqlClient;provider connection string="data source=EQSHEPP1;user id=tismvc;multipleactiveresultsets=True;application name=EntityFramework;App=EntityFramework"</ParameterValue>
      <UpdateDestWebConfig>False</UpdateDestWebConfig>
    </MSDeployParameterValue>
  </ItemGroup>
</Project>